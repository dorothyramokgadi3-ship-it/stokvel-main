// ============================================================
// INTUTHUKO — Prisma Schema V1.1
// "Every table is a tradition. Every field is a reason."
// Pressure-tested. Audited. 16 tables. Ships in 8 weeks.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS — The Language of Stokvels
// ============================================================

enum Language {
  ZU    // isiZulu
  XH    // isiXhosa
  ST    // Sesotho
  EN    // English
}

enum GroupType {
  ROTATING    // Classic: each member gets the pot once per cycle
  SAVINGS     // Pool money, split at year-end (December clubs)
  BURIAL      // Emergency fund for funerals — no rotation
  INVEST      // Pool + invest via licensed partner
  GROCERY     // Monthly grocery pool — bulk buying power
}

enum GroupStatus {
  ACTIVE
  PAUSED        // Temporarily frozen (dispute, December break)
  COMPLETED     // Cycle finished, awaiting new cycle
  DISSOLVED     // Group closed permanently
}

enum MemberRole {
  MEMBER      // Umhlanganyeli — regular member
  SECRETARY   // Unobhala — manages book, adds members
  TREASURER   // Umgcinimafa — manages money, initiates payouts
  CHAIR       // Usihlalo — dispute resolution, tiebreaker
  AUDITOR     // Umcwaningi mabhuku — read-only, verifies hashes
}

enum MemberStatus {
  INVITED     // Sent WhatsApp invite, hasn't joined
  ACTIVE      // Paying member in good standing
  LATE        // Missed 1-2 payments — gentle reminder
  SUSPENDED   // Missed 3+ — frozen until caught up
  LEFT        // Voluntarily departed
  REMOVED     // Voted out by admin consensus
}

enum PaymentMethod {
  OZOW            // Instant EFT via Ozow
  PAYSHAP         // PayShap instant payment
  SNAPSCAN        // SnapScan QR
  RETAIL_VOUCHER  // In-store with reference code (PnP, Shoprite, Spar)
  EFT             // Manual bank transfer + proof upload
  CASH            // Cash at meeting — admin records manually
  WALLET          // Internal wallet transfer
  BANK_TRANSFER   // Direct bank-to-bank
}

enum ContributionStatus {
  PENDING     // Payment initiated, waiting for provider
  CONFIRMED   // Money received and verified
  FAILED      // Payment bounced or declined
  DISPUTED    // Member raised an issue
  REFUNDED    // Reversed — creates new offsetting entry
}

enum PayoutStatus {
  PENDING     // Waiting for multisig approval
  APPROVED    // Quorum reached, ready to execute
  PROCESSING  // Money is being sent
  PAID        // Recipient received funds
  FAILED      // Transfer failed — retry needed
  CANCELLED   // Cancelled before execution
}

enum PayoutMethod {
  EFT         // Standard bank transfer
  EWALLET     // FNB eWallet or similar
  OZOW        // Ozow payout
  CASH        // Cash at meeting
}

enum ApprovalType {
  APPROVED
  REJECTED
  ABSTAINED
}

enum LedgerStatus {
  PENDING     // Cron hasn't run yet
  PUBLISHED   // Hash on Bitcoin/IPFS/Twitter
  VERIFIED    // At least one external verification
  DISPUTED    // Hash challenged — investigate
}

enum DisputeType {
  MISSING_PAYMENT   // "I paid but it's not reflected"
  WRONG_AMOUNT      // "I was charged R600 not R500"
  PAYOUT_DELAY      // "It's my turn but nothing happened"
  FRAUD             // "Someone withdrew without approval"
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED     // Needs NASASA or legal intervention
  CLOSED
}

enum NotificationType {
  PAYMENT_DUE
  PAYMENT_RECEIVED
  PAYMENT_LATE
  PAYOUT_READY
  PAYOUT_SENT
  APPROVAL_NEEDED
  BOOK_CLOSED
  MEMBER_JOINED
  MEMBER_LEFT
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  MEETING_REMINDER
  GROUP_ANNOUNCEMENT
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum Channel {
  WHATSAPP
  SMS
  PUSH
  WEB
  USSD
  CRON
}

enum WalletTransactionType {
  TOPUP
  PAYMENT
  PAYOUT_RECEIVED
  REFUND
  FEE
}

// ============================================================
// 1. USER — The person behind the phone number
// ============================================================
model User {
  id            String      @id @default(cuid())
  phone         String      @unique
  displayName   String?
  idNumber      String?     @unique               // AES-256 encrypted at rest
  language      Language    @default(EN)
  avatarUrl     String?
  isVerified    Boolean     @default(false)
  isPremium     Boolean     @default(false)

  createdAt     DateTime    @default(now())
  lastSeenAt    DateTime?
  deletedAt     DateTime?                          // Soft delete — never hard-delete financial users

  memberships       GroupMember[]
  contributions     Contribution[]
  payoutsReceived   Payout[]          @relation("PayoutRecipient")
  payoutApprovals   PayoutApproval[]
  notifications     Notification[]
  auditLogs         AuditLog[]        @relation("AuditActor")
  wallet            Wallet?
  otpSessions       OtpSession[]
  disputesRaised    Dispute[]         @relation("DisputeRaiser")
  invitesCreated    Invite[]          @relation("InviteCreator")

  @@index([phone])
  @@map("users")
}

// ============================================================
// 2. GROUP — The stokvel circle
// ============================================================
model Group {
  id              String      @id @default(cuid())
  code            String      @unique
  name            String
  description     String?
  type            GroupType

  // Money rules
  monthlyAmount   Int                              // Cents. R500 = 50000.
  currency        String      @default("ZAR")
  payoutDay       Int         @db.SmallInt          // 1-28
  cycleLength     Int         @default(12)
  currentCycle    Int         @default(1)
  maxMembers      Int         @default(12)

  // Multisig
  requiredSigners Int         @default(2)

  // Ledger
  lastLedgerHash  String?
  ledgerDay       DateTime?

  // Trust signals
  totalValueMoved Int         @default(0)
  disputesOpen    Int         @default(0)

  // Quick circle view — denormalized
  nextPayoutUserId String?
  nextPayoutDate   DateTime?

  // Location — province level max (POPIA)
  province        String?                          // "KZN", "GP", "WC"
  city            String?                          // "Soweto", "Umlazi"

  // Status
  status          GroupStatus @default(ACTIVE)
  isPremium       Boolean     @default(false)

  // Bank details — encrypted
  bankName        String?
  bankAccount     String?                          // AES-256 encrypted
  bankReference   String?

  foundedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?                        // Soft delete

  members         GroupMember[]
  contributions   Contribution[]
  payouts         Payout[]
  ledgerEntries   LedgerEntry[]
  disputes        Dispute[]
  meetings        Meeting[]
  rules           Rule[]
  invites         Invite[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([code])
  @@index([type, province])
  @@index([status])
  @@map("groups")
}

// ============================================================
// 3. GROUP MEMBER — Your seat at the table
// ============================================================
model GroupMember {
  id                String       @id @default(cuid())
  userId            String
  groupId           String
  role              MemberRole   @default(MEMBER)
  rotationPosition  Int?
  status            MemberStatus @default(ACTIVE)
  joinedAt          DateTime     @default(now())
  leftAt            DateTime?
  invitedBy         String?

  totalContributed  Int          @default(0)
  totalReceived     Int          @default(0)
  missedPayments    Int          @default(0)
  lastPaymentAt     DateTime?

  // CHAIR=2, TREASURER=2, SECRETARY=1, MEMBER=1, AUDITOR=0
  sigWeight         Int          @default(1)

  user              User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  group             Group        @relation(fields: [groupId], references: [id], onDelete: Restrict)
  approvals         PayoutApproval[]

  @@unique([userId, groupId])
  @@index([groupId, status])
  @@index([groupId, rotationPosition])
  @@index([userId])
  @@map("group_members")
}

// ============================================================
// 4. CONTRIBUTION — Every rand entering the circle
// APPEND-ONLY: No UPDATE, no DELETE. Enforced at DB level.
// ============================================================
model Contribution {
  id              String              @id @default(cuid())
  groupId         String
  userId          String
  amountCents     Int
  feeAmountCents  Int                 @default(0)    // Platform fee. R0 for free tier.
  netAmountCents  Int                                // amountCents - feeAmountCents = pot
  forMonth        DateTime
  forCycle        Int

  method          PaymentMethod
  reference       String?                            // Ozow txnId, "SPAR TILL 42", or null for CASH
  proofUrl        String?
  proofVerifiedBy String?
  proofVerifiedAt DateTime?

  status          ContributionStatus  @default(PENDING)
  confirmedAt     DateTime?

  ledgerEntryId   String?
  ledgerEntry     LedgerEntry?        @relation(fields: [ledgerEntryId], references: [id])
  group           Group               @relation(fields: [groupId], references: [id], onDelete: Restrict)
  user            User                @relation(fields: [userId], references: [id], onDelete: Restrict)

  createdAt       DateTime            @default(now())

  @@index([groupId, forMonth])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([reference])
  @@map("contributions")
}

// ============================================================
// 5. PAYOUT — Every rand leaving the circle
// APPEND-ONLY. 2-of-N keys to the money box.
// ============================================================
model Payout {
  id                String       @id @default(cuid())
  groupId           String
  recipientUserId   String
  amountCents       Int
  forMonth          DateTime
  forCycle          Int

  payoutMethod      PayoutMethod
  bankName          String?
  bankAccount       String?                          // AES-256 encrypted
  bankBranch        String?
  mobileWallet      String?

  requiredApprovals Int
  currentApprovals  Int          @default(0)

  status            PayoutStatus @default(PENDING)
  scheduledFor      DateTime
  paidAt            DateTime?

  externalRef       String?
  externalStatus    String?

  ledgerEntryId     String?
  ledgerEntry       LedgerEntry? @relation(fields: [ledgerEntryId], references: [id])
  group             Group        @relation(fields: [groupId], references: [id], onDelete: Restrict)
  recipient         User         @relation("PayoutRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)
  approvals         PayoutApproval[]

  createdAt         DateTime     @default(now())

  @@index([groupId, status])
  @@index([scheduledFor])
  @@index([recipientUserId])
  @@map("payouts")
}

// ============================================================
// 6. PAYOUT APPROVAL — Each key turned in the money box
// APPEND-ONLY. One vote per admin per payout.
// ============================================================
model PayoutApproval {
  id          String        @id @default(cuid())
  payoutId    String
  approverId  String

  decision    ApprovalType
  reason      String?
  channel     Channel
  signedAt    DateTime      @default(now())

  payout      Payout        @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  approver    User          @relation(fields: [approverId], references: [id], onDelete: Restrict)

  @@unique([payoutId, approverId])
  @@map("payout_approvals")
}

// ============================================================
// 7. WALLET
// ============================================================
model Wallet {
  id              String          @id @default(cuid())
  userId          String          @unique
  balanceCents    Int             @default(0)
  dailyLimitCents Int            @default(5000000)
  monthlyLimitCents Int          @default(25000000)

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions    WalletTransaction[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("wallets")
}

// APPEND-ONLY.
model WalletTransaction {
  id              String                @id @default(cuid())
  walletId        String
  type            WalletTransactionType
  amountCents     Int
  balanceAfter    Int
  description     String
  referenceType   String?
  referenceId     String?

  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Restrict)

  createdAt       DateTime        @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

// ============================================================
// 8. LEDGER ENTRY — The book that can't burn
// APPEND-ONLY. Hash chain is tamper-evident.
// ============================================================
model LedgerEntry {
  id              String       @id @default(cuid())
  groupId         String
  date            DateTime     @db.Date
  dataHash        String       @unique
  previousHash    String?
  merkleRoot      String?

  ipfsCid         String?
  bitcoinTxHash   String?
  tweetUrl        String?
  rawDataUrl      String?

  totalInCents    Int          @default(0)
  totalOutCents   Int          @default(0)
  transactionCount Int         @default(0)
  memberCount     Int          @default(0)

  status          LedgerStatus @default(PENDING)

  group           Group        @relation(fields: [groupId], references: [id], onDelete: Restrict)
  contributions   Contribution[]
  payouts         Payout[]

  createdAt       DateTime     @default(now())
  publishedAt     DateTime?

  @@unique([groupId, date])
  @@index([dataHash])
  @@map("ledger_entries")
}

// ============================================================
// 9. DISPUTE
// ============================================================
model Dispute {
  id              String         @id @default(cuid())
  groupId         String
  raisedByUserId  String
  againstUserId   String?

  type            DisputeType
  description     String
  evidenceUrls    String[]

  status          DisputeStatus  @default(OPEN)
  resolution      String?
  resolvedBy      String?
  resolvedAt      DateTime?

  group           Group          @relation(fields: [groupId], references: [id], onDelete: Restrict)
  raisedBy        User           @relation("DisputeRaiser", fields: [raisedByUserId], references: [id], onDelete: Restrict)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([groupId, status])
  @@map("disputes")
}

// ============================================================
// 10. OTP SESSION
// ============================================================
model OtpSession {
  id          String    @id @default(cuid())
  userId      String?
  phone       String
  codeHash    String                                 // bcrypt hashed
  channel     Channel   @default(WHATSAPP)
  attempts    Int       @default(0)
  isUsed      Boolean   @default(false)
  expiresAt   DateTime
  usedAt      DateTime?

  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())

  @@index([phone, expiresAt])
  @@map("otp_sessions")
}

// ============================================================
// 11. NOTIFICATION
// ============================================================
model Notification {
  id          String            @id @default(cuid())
  userId      String
  groupId     String?

  type        NotificationType
  channel     Channel           @default(WHATSAPP)
  title       String
  body        String
  ctaUrl      String?

  status      DeliveryStatus    @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt   DateTime          @default(now())

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// 12. AUDIT LOG — APPEND-ONLY. NO UPDATE. NO DELETE. EVER.
// ============================================================
model AuditLog {
  id            String    @id @default(cuid())
  actorUserId   String?
  groupId       String?

  action        String
  entityType    String
  entityId      String
  metadata      Json?

  channel       Channel   @default(WEB)
  ipAddress     String?
  userAgent     String?

  actor         User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  group         Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())

  @@index([groupId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================================
// 13. MEETING
// ============================================================
model Meeting {
  id            String    @id @default(cuid())
  groupId       String

  title         String
  venue         String?
  scheduledAt   DateTime
  durationMins  Int       @default(60)
  minutesUrl    String?
  agenda        String?

  attendees     String[]
  absentees     String[]

  isVirtual     Boolean   @default(false)
  meetingLink   String?

  group         Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([groupId, scheduledAt])
  @@map("meetings")
}

// ============================================================
// 14. RULE — The group's constitution
// ============================================================
model Rule {
  id          String    @id @default(cuid())
  groupId     String

  key         String
  value       String
  label       String
  description String?
  enforced    Boolean   @default(true)
  changedBy   String?

  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([groupId, key])
  @@map("rules")
}

// ============================================================
// 15. INVITE — Viral growth through trust chains
// ============================================================
model Invite {
  id          String    @id @default(cuid())
  groupId     String
  code        String    @unique
  createdBy   String

  maxUses     Int       @default(5)
  usedCount   Int       @default(0)
  expiresAt   DateTime
  isActive    Boolean   @default(true)

  usedBy      String[]

  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User      @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([groupId, isActive])
  @@map("invites")
}
