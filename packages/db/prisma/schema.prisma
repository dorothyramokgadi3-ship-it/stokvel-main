// ============================================================
// INTUTHUKO — Prisma Schema V1.0
// "Every table is a tradition. Every field is a reason."
// Pressure-tested. 16 tables. Ships in 8 weeks.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS — The Language of Stokvels
// ============================================================

enum Language {
  zu    // isiZulu
  xh    // isiXhosa
  st    // Sesotho
  en    // English
}

enum GroupType {
  ROTATING    // Classic: each member gets the pot once per cycle
  SAVINGS     // Pool money, split at year-end (December clubs)
  BURIAL      // Emergency fund for funerals — no rotation
  INVEST      // Pool + invest via licensed partner
  GROCERY     // Monthly grocery pool — bulk buying power
}

enum MemberRole {
  MEMBER      // Umhlanganyeli — regular member
  SECRETARY   // Unobhala — manages book, adds members
  TREASURER   // Umgcinimafa — manages money, initiates payouts
  CHAIR       // Usihlalo — dispute resolution, tiebreaker
  AUDITOR     // Umcwaningi mabhuku — read-only, verifies hashes
}

enum MemberStatus {
  INVITED     // Sent WhatsApp invite, hasn't joined
  ACTIVE      // Paying member in good standing
  LATE        // Missed 1-2 payments — gentle reminder
  SUSPENDED   // Missed 3+ — frozen until caught up
  LEFT        // Voluntarily departed
  REMOVED     // Voted out by admin consensus
}

enum PaymentMethod {
  OZOW            // Instant EFT via Ozow
  PAYSHAP         // PayShap instant payment
  SNAPSCAN        // SnapScan QR
  RETAIL_VOUCHER  // In-store with reference code (PnP, Shoprite, Spar)
  EFT             // Manual bank transfer + proof upload
  CASH            // Cash at meeting — admin records manually
  WALLET          // Internal wallet transfer
  BANK_TRANSFER   // Direct bank-to-bank
}

enum ContributionStatus {
  PENDING     // Payment initiated, waiting for provider
  CONFIRMED   // Money received and verified
  FAILED      // Payment bounced or declined
  DISPUTED    // Member raised an issue
  REFUNDED    // Reversed — creates new offsetting entry
}

enum PayoutStatus {
  PENDING     // Waiting for multisig approval
  APPROVED    // Quorum reached, ready to execute
  PROCESSING  // Money is being sent
  PAID        // Recipient received funds
  FAILED      // Transfer failed — retry needed
  CANCELLED   // Cancelled before execution
}

enum PayoutMethod {
  EFT         // Standard bank transfer
  EWALLET     // FNB eWallet or similar
  OZOW        // Ozow payout
  CASH        // Cash at meeting
}

enum ApprovalType {
  APPROVED
  REJECTED
  ABSTAINED
}

enum LedgerStatus {
  PENDING     // Cron hasn't run yet
  PUBLISHED   // Hash on Bitcoin/IPFS/Twitter
  VERIFIED    // At least one external verification
  DISPUTED    // Hash challenged — investigate
}

enum DisputeType {
  MISSING_PAYMENT   // "I paid but it's not reflected"
  WRONG_AMOUNT      // "I was charged R600 not R500"
  PAYOUT_DELAY      // "It's my turn but nothing happened"
  FRAUD             // "Someone withdrew without approval"
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED     // Needs NASASA or legal intervention
  CLOSED
}

enum NotificationType {
  PAYMENT_DUE       // "Tomorrow is payday"
  PAYMENT_RECEIVED  // "Mama Nomsa paid R500"
  PAYMENT_LATE      // "Gentle reminder: your R500 is 3 days overdue"
  PAYOUT_READY      // "Your turn! R6,000 is ready for approval"
  PAYOUT_SENT       // "R6,000 sent to your FNB account"
  APPROVAL_NEEDED   // "Treasurer: approve Khethiwe's payout"
  BOOK_CLOSED       // "Today's book is closed. Hash: a7f3..."
  MEMBER_JOINED     // "Welcome Thandi to Masakhane!"
  MEMBER_LEFT       // "Sipho has left the group"
  DISPUTE_OPENED    // "A dispute was raised"
  DISPUTE_RESOLVED  // "Dispute resolved: payment credited"
  MEETING_REMINDER  // "Meeting Sunday 2pm at Khethiwe's"
  GROUP_ANNOUNCEMENT // Admin broadcast
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum Channel {
  whatsapp
  sms
  push
  web
  ussd
  cron
}

enum WalletTransactionType {
  TOPUP           // Money in from external source
  PAYMENT         // Money out to group contribution
  PAYOUT_RECEIVED // Money in from group payout
  REFUND          // Reversal
  FEE             // Platform fee deducted
}

// ============================================================
// 1. USER — The person behind the phone number
// ============================================================
// In a stokvel, you ARE your phone number. No email, no username.
// Gogo doesn't have Gmail. She has WhatsApp.
model User {
  id            String      @id @default(cuid())
  phone         String      @unique               // +27... E.164 — the ONLY identity
  displayName   String?                            // "Mama Nomsa" — what the group calls you
  idNumber      String?     @unique               // AES-256 encrypted at rest. KYC only when money > R25k/month
  language      Language    @default(en)           // zu, xh, st, en — for voice notes & bot replies
  avatarUrl     String?                            // WhatsApp profile pic, pulled on first contact
  isVerified    Boolean     @default(false)        // Phone OTP confirmed
  isPremium     Boolean     @default(false)        // R29/group subscriber

  createdAt     DateTime    @default(now())
  lastSeenAt    DateTime?                          // Last bot or web interaction
  // NO updatedAt — phone never changes, name rarely

  // Relations
  memberships     GroupMember[]
  contributions   Contribution[]
  payoutsReceived Payout[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  wallet          Wallet?
  otpSessions     OtpSession[]
  disputesRaised  Dispute[]       @relation("DisputeRaiser")

  @@index([phone])
  @@map("users")
}

// ============================================================
// 2. GROUP — The stokvel itself
// ============================================================
// A stokvel is not a "team". It's a circle.
// It has a name, a monthly amount, a rotation order, and rules
// agreed upon in a meeting — not a settings page.
model Group {
  id              String      @id @default(cuid())
  code            String      @unique              // "MAS123" — human shareable join code
  name            String                           // "Masakhane Savings Club"
  description     String?                          // "Est. 2019, Soweto. Monthly R500."
  type            GroupType                        // ROTATING|SAVINGS|BURIAL|INVEST|GROCERY

  // Money rules — set once at creation, change needs full consensus
  monthlyAmount   Int                              // In cents. R500 = 50000. No decimals.
  currency        String      @default("ZAR")      // Always ZAR. No crypto.
  payoutDay       Int         @db.SmallInt          // 1-28, avoids month-end chaos
  cycleLength     Int         @default(12)          // Months per full rotation
  currentCycle    Int         @default(1)           // Which cycle we're in
  maxMembers      Int         @default(12)          // Dunbar's number — trust breaks after

  // Multisig config — THE TRADITION
  requiredSigners Int         @default(2)           // 2-of-3, 3-of-5, etc.

  // Ledger link — THE PROOF
  lastLedgerHash  String?                          // SHA-256 of yesterday's CSV
  ledgerDay       DateTime?                        // Last time book was closed

  // Trust signals — psychology metrics
  totalValueMoved Int         @default(0)           // Sum all contributions ever (cents)
  disputesOpen    Int         @default(0)           // Red flag if > 0

  // Status
  status          GroupStatus @default(ACTIVE)
  isPremium       Boolean     @default(false)

  // Bank details — for EFT payments TO the group
  bankName        String?                          // "FNB" — partner bank
  bankAccount     String?                          // AES-256 encrypted. Only admins see
  bankReference   String?                          // Auto-generated per group

  foundedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  members         GroupMember[]
  contributions   Contribution[]
  payouts         Payout[]
  ledgerEntries   LedgerEntry[]
  disputes        Dispute[]
  meetings        Meeting[]
  rules           Rule[]
  invites         Invite[]
  auditLogs       AuditLog[]

  @@index([code])
  @@index([type, foundedAt])                       // Discovery: "Show me BURIAL groups in KZN"
  @@index([status])
  @@map("groups")
}

enum GroupStatus {
  ACTIVE
  PAUSED        // Temporarily frozen (dispute, December break)
  COMPLETED     // Cycle finished, awaiting new cycle
  DISSOLVED     // Group closed permanently
}

// ============================================================
// 3. GROUP MEMBER — Your seat at the table
// ============================================================
// In a stokvel, your ROLE matters. The treasurer is not the chair.
// Your POSITION in rotation determines when you get paid.
// "Position 3" means you get the pot in month 3.
model GroupMember {
  id                String       @id @default(cuid())
  userId            String
  groupId           String
  role              MemberRole   @default(MEMBER)
  rotationPosition  Int?                            // 1 = Jan payout, null if SAVINGS type
  status            MemberStatus @default(ACTIVE)
  joinedAt          DateTime     @default(now())
  leftAt            DateTime?
  invitedBy         String?                          // cuid of who invited them

  // Trust metrics — psychology, not just data
  totalContributed  Int          @default(0)          // Running cents total
  totalReceived     Int          @default(0)          // Total payouts received
  missedPayments    Int          @default(0)          // 3 = auto SUSPENDED
  lastPaymentAt     DateTime?

  // Multisig weight — elder votes count more
  // CHAIR=2, TREASURER=2, SECRETARY=1, MEMBER=1, AUDITOR=0
  sigWeight         Int          @default(1)

  user              User         @relation(fields: [userId], references: [id])
  group             Group        @relation(fields: [groupId], references: [id])
  approvals         PayoutApproval[]

  @@unique([userId, groupId])                        // One seat per person per circle
  @@index([groupId, status])                         // "Show me ACTIVE members"
  @@index([groupId, rotationPosition])               // "Who's next?"
  @@index([userId])
  @@map("group_members")
}

// ============================================================
// 4. CONTRIBUTION — Every rand that enters the circle
// ============================================================
// A contribution is sacred. It's a promise kept.
// The book records: WHO paid, WHEN, HOW MUCH, and HOW.
// No editing. No deleting. Append-only like tradition.
model Contribution {
  id              String              @id @default(cuid())
  groupId         String
  userId          String                             // Who paid
  amountCents     Int                                // 50000 = R500. Always cents.
  forMonth        DateTime                           // 2026-05-01 = "May contribution"
  forCycle        Int                                // Which rotation cycle

  // How the money arrived
  method          PaymentMethod
  reference       String                             // Ozow txnId, or "SPAR TILL 42"
  proofUrl        String?                            // R2 image of bank slip, if CASH/EFT
  proofVerifiedBy String?                            // Admin who approved manual proof
  proofVerifiedAt DateTime?

  // Status — the journey of a payment
  status          ContributionStatus  @default(PENDING)
  confirmedAt     DateTime?                          // When bank webhook hit

  // Ledger link
  ledgerEntryId   String?
  ledgerEntry     LedgerEntry?        @relation(fields: [ledgerEntryId], references: [id])

  group           Group               @relation(fields: [groupId], references: [id])
  user            User                @relation(fields: [userId], references: [id])

  createdAt       DateTime            @default(now())
  // NO updatedAt — if wrong, create REFUND + new Contribution. Never edit money.

  @@index([groupId, forMonth])                       // "Who paid May?"
  @@index([userId, status])                          // "Show Mama Nomsa her history"
  @@index([status, createdAt])                       // Cron: find PENDING > 24h old
  @@index([reference])                               // Webhook: "Ozow says TX123 succeeded"
  @@map("contributions")
}

// ============================================================
// 5. PAYOUT — Every rand that leaves the circle
// ============================================================
// Payouts are the moment of truth. In a rotating stokvel,
// this is YOUR month. The pot goes to you.
// But nobody moves money alone. 2-of-3 keys to the box.
model Payout {
  id                String       @id @default(cuid())
  groupId           String
  recipientUserId   String                           // Who gets paid
  amountCents       Int
  forMonth          DateTime                         // "May payout"
  forCycle          Int

  // Where to send the money
  payoutMethod      PayoutMethod
  bankName          String?                          // Recipient's bank
  bankAccount       String?                          // AES-256 encrypted
  bankBranch        String?
  mobileWallet      String?                          // For eWallet payouts

  // Multisig — "2 keys to the money box"
  requiredApprovals Int                              // Copied from Group.requiredSigners
  currentApprovals  Int          @default(0)

  // Status
  status            PayoutStatus @default(PENDING)
  scheduledFor      DateTime                         // PayoutDay of month
  paidAt            DateTime?

  // External payment reference
  externalRef       String?
  externalStatus    String?

  // Ledger link
  ledgerEntryId     String?
  ledgerEntry       LedgerEntry? @relation(fields: [ledgerEntryId], references: [id])

  group             Group        @relation(fields: [groupId], references: [id])
  recipient         User         @relation(fields: [recipientUserId], references: [id])
  approvals         PayoutApproval[]

  createdAt         DateTime     @default(now())

  @@index([groupId, status])                         // "Show pending payouts"
  @@index([scheduledFor])                            // Cron: process today's payouts
  @@index([recipientUserId])
  @@map("payouts")
}

// ============================================================
// 6. PAYOUT APPROVAL — Each key turned in the money box
// ============================================================
// Every admin who approves a payout leaves a signature.
// Transparent. Auditable. No "I didn't approve that."
model PayoutApproval {
  id          String        @id @default(cuid())
  payoutId    String
  approverId  String                                // FK to User via GroupMember

  decision    ApprovalType                          // APPROVED|REJECTED|ABSTAINED
  reason      String?                               // "Confirmed with Khethiwe on call"
  channel     Channel                               // whatsapp|web|ussd — proves human did it
  signedAt    DateTime      @default(now())

  payout      Payout        @relation(fields: [payoutId], references: [id])
  approver    GroupMember    @relation(fields: [approverId], references: [id])

  @@unique([payoutId, approverId])                  // One vote per elder per payout
  @@map("payout_approvals")
}

// ============================================================
// 7. WALLET — Cash in your pocket at the meeting
// ============================================================
// Some members pre-load money. Wallet-to-group is instant.
// No waiting for EFT. Like cash in your pocket at the meeting.
model Wallet {
  id              String          @id @default(cuid())
  userId          String          @unique
  balanceCents    Int             @default(0)
  dailyLimitCents Int            @default(5000000)   // R50k — AML limit
  monthlyLimitCents Int          @default(25000000)  // R250k monthly

  user            User            @relation(fields: [userId], references: [id])
  transactions    WalletTransaction[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id              String                @id @default(cuid())
  walletId        String
  type            WalletTransactionType
  amountCents     Int                                // Always positive. Direction from type.
  balanceAfter    Int                                // Snapshot for reconciliation
  description     String                             // "Paid R500 to Masakhane (May 2026)"
  referenceType   String?                            // "contribution" | "payout" | "topup"
  referenceId     String?

  wallet          Wallet          @relation(fields: [walletId], references: [id])

  createdAt       DateTime        @default(now())

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

// ============================================================
// 8. LEDGER ENTRY — The book that can't burn
// ============================================================
// Every night at 8pm SAST, we close the book.
// Hash every transaction. Publish the proof.
// This is the "book on the table" — digital, immutable.
model LedgerEntry {
  id              String       @id @default(cuid())
  groupId         String
  date            DateTime     @db.Date              // 2026-05-01
  dataHash        String       @unique               // SHA-256 of CSV
  previousHash    String?                            // Chain to yesterday — tamper evident
  merkleRoot      String?                            // If part of nightly batch

  // External proof — where anyone can verify
  ipfsCid         String?                            // QmXxx... — CSV stored forever
  bitcoinTxHash   String?                            // OP_RETURN txid — timestamp proof
  tweetUrl        String?                            // Public announcement URL
  rawDataUrl      String?                            // R2 URL of the CSV

  // Summary stats (denormalized for quick display)
  totalInCents    Int          @default(0)
  totalOutCents   Int          @default(0)
  transactionCount Int         @default(0)
  memberCount     Int          @default(0)            // Snapshot at time of close

  status          LedgerStatus @default(PENDING)

  group           Group        @relation(fields: [groupId], references: [id])
  contributions   Contribution[]
  payouts         Payout[]

  createdAt       DateTime     @default(now())
  publishedAt     DateTime?

  @@unique([groupId, date])                          // One entry per group per day
  @@index([dataHash])                                // "Verify this hash"
  @@index([groupId, date])
  @@map("ledger_entries")
}

// ============================================================
// 9. DISPUTE — When trust breaks, the process heals
// ============================================================
// Stokvels have disputes. "I paid but it's not showing."
// Traditional stokvels handle this in meetings.
// We handle it with evidence + votes.
model Dispute {
  id              String         @id @default(cuid())
  groupId         String
  raisedByUserId  String
  againstUserId   String?                            // Or null if "group vs bank"

  type            DisputeType
  description     String                             // "I paid at Spar but not reflected"
  evidenceUrls    String[]                           // Photos of slips

  status          DisputeStatus  @default(OPEN)
  resolution      String?                            // "Admin confirmed with bank, marked PAID"
  resolvedBy      String?                            // Admin userId
  resolvedAt      DateTime?

  group           Group          @relation(fields: [groupId], references: [id])
  raisedBy        User           @relation("DisputeRaiser", fields: [raisedByUserId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([groupId, status])                         // "Show open disputes" — red flag metric
  @@map("disputes")
}

// ============================================================
// 10. OTP SESSION — WhatsApp is the login
// ============================================================
// No passwords. No email. Your phone IS your identity.
// Send OTP via WhatsApp → verify → issue JWT httpOnly cookie.
model OtpSession {
  id          String    @id @default(cuid())
  userId      String?
  phone       String                                 // +27... E.164
  codeHash    String                                 // bcrypt hashed, NEVER plaintext
  channel     Channel   @default(whatsapp)            // whatsapp|sms|ussd
  attempts    Int       @default(0)                   // Max 3 before cooldown
  isUsed      Boolean   @default(false)
  expiresAt   DateTime                               // Now + 5 min
  usedAt      DateTime?

  user        User?     @relation(fields: [userId], references: [id])

  createdAt   DateTime  @default(now())

  @@index([phone, expiresAt])                        // Cleanup cron
  @@map("otp_sessions")
}

// ============================================================
// 11. NOTIFICATION — Nudges that feel human
// ============================================================
// "Mama Nomsa, your R500 keeps Masakhane strong."
// Not "Your transaction #8472 is complete."
model Notification {
  id          String            @id @default(cuid())
  userId      String
  groupId     String?

  type        NotificationType
  channel     Channel           @default(whatsapp)
  title       String                                 // "Masakhane: Your turn next month"
  body        String                                 // Human elder language, not robot
  ctaUrl      String?                                // Deep link to pay/approve/view

  status      DeliveryStatus    @default(PENDING)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?

  user        User              @relation(fields: [userId], references: [id])

  createdAt   DateTime          @default(now())

  @@index([userId, status])                          // "Show unread"
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// 12. AUDIT LOG — The book behind the book
// ============================================================
// In a traditional stokvel, the book is the record.
// In Intuthuko, the audit log is the book behind the book.
// Who did what, when, from where. Non-negotiable.
// NO UPDATE, NO DELETE on this table. Ever.
model AuditLog {
  id            String    @id @default(cuid())
  actorUserId   String?                              // Null if system/cron
  groupId       String?

  action        String                               // "payout.approved", "member.removed"
  entityType    String                               // "Payout", "GroupMember"
  entityId      String
  metadata      Json?                                // { before: {status: PENDING}, after: {status: APPROVED} }

  channel       Channel   @default(web)              // whatsapp|web|ussd|cron
  ipAddress     String?
  userAgent     String?

  actor         User?     @relation(fields: [actorUserId], references: [id])
  group         Group?    @relation(fields: [groupId], references: [id])

  createdAt     DateTime  @default(now())

  @@index([groupId, createdAt])                      // "Show group history"
  @@index([actorUserId, createdAt])                  // "What did treasurer do?"
  @@index([entityType, entityId])                    // "All events for Payout X"
  @@map("audit_logs")
}

// ============================================================
// 13. MEETING — Some groups still meet physically
// ============================================================
// "Meeting Sunday 2pm at Khethiwe's. Reply 1 if attending."
// Digital doesn't kill tradition. It supports it.
model Meeting {
  id            String    @id @default(cuid())
  groupId       String

  title         String                               // "May Monthly Meeting"
  venue         String?                              // "Khethiwe's house, Soweto"
  scheduledAt   DateTime                             // When
  durationMins  Int       @default(60)
  minutesUrl    String?                              // R2 URL of meeting minutes PDF
  agenda        String?                              // "1. May payouts 2. New member vote"

  // Attendance — tracked for accountability
  attendees     String[]                             // Array of User IDs who attended
  absentees     String[]                             // Array of User IDs who didn't show

  isVirtual     Boolean   @default(false)            // WhatsApp group call counts
  meetingLink   String?                              // If virtual

  group         Group     @relation(fields: [groupId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([groupId, scheduledAt])
  @@map("meetings")
}

// ============================================================
// 14. RULE — The group's constitution, codified
// ============================================================
// "Late fee: R50". "3 missed = removed". "No loans to non-members."
// Every stokvel has unwritten rules. We write them down.
// Changes need consensus, not a settings page.
model Rule {
  id          String    @id @default(cuid())
  groupId     String

  key         String                                 // "late_fee" | "max_missed" | "payout_order"
  value       String                                 // "5000" (cents) | "3" | "rotation"
  label       String                                 // "Late Payment Fee" — human readable
  description String?                                // "R50 charged if payment is 7+ days late"
  enforced    Boolean   @default(true)               // Is the system enforcing this automatically?
  changedBy   String?                                // User ID of who last changed it

  group       Group     @relation(fields: [groupId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([groupId, key])                           // One rule per key per group
  @@map("rules")
}

// ============================================================
// 15. INVITE — Viral growth through trust chains
// ============================================================
// Admin shares link in WhatsApp: "Join Masakhane: intuthuko.co.za/join/MAS123-X7K"
// Tracks who invited who — the trust chain.
// Expires, has max uses — no open doors to strangers.
model Invite {
  id          String    @id @default(cuid())
  groupId     String
  code        String    @unique                      // "MAS123-X7K" — unique invite code
  createdBy   String                                 // Admin who created it

  maxUses     Int       @default(5)                  // How many people can use this link
  usedCount   Int       @default(0)                  // How many have joined
  expiresAt   DateTime                               // Auto-expire after 7 days
  isActive    Boolean   @default(true)

  // Tracking — who used this invite
  usedBy      String[]                               // Array of User IDs who joined via this

  group       Group     @relation(fields: [groupId], references: [id])

  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([groupId, isActive])
  @@map("invites")
}

// ============================================================
// 16. WALLET TRANSACTION — Ledger for the pocket money
// ============================================================
// Already defined above under Wallet section
